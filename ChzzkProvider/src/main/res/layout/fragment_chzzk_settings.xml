<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/chzzkSettingsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_settings_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Login section -->
        <TextView
            android:id="@+id/chzzkSectionLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_section_login"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/chzzkLoginExplainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_login_explainer"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/chzzkLoginStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_login_status_out"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/chzzkInputAutLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/chzzk_hint_nid_aut"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/chzzkInputAut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/chzzkInputSesLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/chzzk_hint_nid_ses"
            android:layout_marginBottom="10dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/chzzkInputSes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/chzzkBtnSaveLogin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/chzzk_action_save_login" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/chzzkBtnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chzzk_action_logout" />
        </LinearLayout>

        <!-- Playback section -->
        <TextView
            android:id="@+id/chzzkSectionPlayback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_section_playback"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/chzzkSwitchLlhls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_switch_llhls" />

        <TextView
            android:id="@+id/chzzkSwitchLlhlsDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_switch_llhls_desc"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <!-- Cache section -->
        <TextView
            android:id="@+id/chzzkSectionCache"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_section_cache"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/chzzkCacheExplainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_cache_explainer"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/chzzkBtnClearCache"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_action_clear_cache"
            android:layout_marginBottom="20dp" />

        <!-- Status section -->
        <TextView
            android:id="@+id/chzzkSectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_section_status"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/chzzkFeatureList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chzzk_feature_list"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</ScrollView>
